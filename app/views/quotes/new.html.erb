<!-- New Quote Form Page -->
<div class="max-w-3xl mx-auto px-4 py-8">
  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">
      ✨ Yeni Söz Ekle
    </h1>
    <p class="text-xl text-gray-600">
      İlham veren sözünüzü ya da komik anınızı toplulukla paylaşın
    </p>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
    <div class="bg-gradient-to-r from-purple-500 to-pink-500 p-6">
      <h2 class="text-2xl font-bold text-white text-center">
        Hikayenizi Paylaşın
      </h2>
    </div>

    <div class="p-8">
      <%= form_with(model: [@quote], local: true, data: { turbo: false }, class: "space-y-6") do |form| %>
        
        <!-- User Information Section -->
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            Kullanıcı Bilgileri
          </h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <%= label_tag "user[first_name]", "Ad *", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= text_field_tag "user[first_name]", params.dig(:user, :first_name), placeholder: "Adınız", required: true, class: "w-full p-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
            </div>
            
            <div>
              <%= label_tag "user[last_name]", "Soyad *", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= text_field_tag "user[last_name]", params.dig(:user, :last_name), placeholder: "Soyadınız", required: true, class: "w-full p-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
            </div>
          </div>
          
          <div class="mt-4">
            <%= label_tag "user[linkedin_url]", "LinkedIn Profili (Opsiyonel)", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= url_field_tag "user[linkedin_url]", params.dig(:user, :linkedin_url), placeholder: "https://linkedin.com/in/kullanici-adi", class: "w-full p-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
            <p class="text-sm text-gray-500 mt-1">LinkedIn profiliniz varsa ekleyin, insanlar sizi tanısın!</p>
          </div>
        </div>

        <!-- Quote Information Section -->
        <div>
          <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Söz Bilgileri
          </h3>

          <!-- Quote Type Selection -->
          <div class="mb-6">
            <%= form.label :quote_type, "Söz Türü *", class: "block text-sm font-medium text-gray-700 mb-3" %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <label class="relative">
                <%= form.radio_button :quote_type, "inspiring", class: "sr-only peer", required: true %>
                <div class="p-6 border-2 border-gray-200 rounded-xl cursor-pointer peer-checked:border-purple-500 peer-checked:bg-purple-50 hover:border-purple-300 transition-all">
                  <div class="text-center">
                    <div class="text-4xl mb-3">💫</div>
                    <h4 class="text-lg font-semibold text-gray-900 mb-2">İlham Verici</h4>
                    <p class="text-sm text-gray-600">Motivasyon veren, düşündüren ve ilham kaynağı olan sözler</p>
                  </div>
                </div>
              </label>

              <label class="relative">
                <%= form.radio_button :quote_type, "joke", class: "sr-only peer", required: true %>
                <div class="p-6 border-2 border-gray-200 rounded-xl cursor-pointer peer-checked:border-yellow-500 peer-checked:bg-yellow-50 hover:border-yellow-300 transition-all">
                  <div class="text-center">
                    <div class="text-4xl mb-3">😂</div>
                    <h4 class="text-lg font-semibold text-gray-900 mb-2">Komik</h4>
                    <p class="text-sm text-gray-600">Gülümsetici, eğlenceli ve mizahi sözler</p>
                  </div>
                </div>
              </label>
            </div>
          </div>

          <!-- Quote Content -->
          <div class="mb-6">
            <%= form.label :content, "Sözünüz *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_area :content, placeholder: "Sözünüzü buraya yazın...\n\nÖrnek:\n\"Başarı, tutku ile çalışmanın sonucudur.\"", rows: 6, required: true, maxlength: 1000, class: "w-full p-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none" %>
            <div class="flex justify-between items-center mt-2">
              <p class="text-sm text-gray-500">Minimum 10, maksimum 1000 karakter</p>
              <span id="char-count" class="text-sm text-gray-500">0/1000</span>
            </div>
          </div>
        </div>

        <!-- Error Messages -->
        <% if @quote&.errors&.any? || @user&.errors&.any? %>
          <div class="bg-red-50 border border-red-200 rounded-xl p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  Lütfen aşağıdaki hataları düzeltin:
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc list-inside space-y-1">
                    <% (@quote&.errors&.full_messages || []).each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                    <% (@user&.errors&.full_messages || []).each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Form Actions -->
        <div class="border-t border-gray-200 pt-6">
          <div class="flex flex-col sm:flex-row gap-4 sm:justify-between sm:items-center">
            <%= link_to root_path, class: "text-gray-600 hover:text-gray-900 font-medium transition-colors text-center sm:text-left" do %>
              ← Ana Sayfaya Dön
            <% end %>
            
            <div class="flex flex-col sm:flex-row gap-3">
              <button type="button" class="px-6 py-3 border border-gray-200 rounded-xl text-gray-700 font-medium hover:bg-gray-50 transition-colors" onclick="document.querySelector('form').reset(); updateCharCount();">
                Formu Temizle
              </button>
              
              <%= form.submit "Sözü Yayınla", class: "bg-gradient-to-r from-purple-500 to-pink-500 text-white px-8 py-3 rounded-xl font-medium hover:from-purple-600 hover:to-pink-600 transition-all transform hover:scale-105 shadow-lg" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Tips Section -->
  <div class="mt-12 bg-blue-50 rounded-2xl p-6">
    <h3 class="text-lg font-semibold text-blue-900 mb-4 flex items-center">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      İpuçları
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-white rounded-xl p-4">
        <h4 class="font-semibold text-gray-900 mb-2">💫 İlham Verici Sözler İçin:</h4>
        <ul class="text-sm text-gray-600 space-y-1">
          <li>• Kişisel deneyimlerinizden yola çıkın</li>
          <li>• Motivasyon verici olsun</li>
          <li>• Pozitif mesaj içersin</li>
        </ul>
      </div>
      
      <div class="bg-white rounded-xl p-4">
        <h4 class="font-semibold text-gray-900 mb-2">😂 Komik Sözler İçin:</h4>
        <ul class="text-sm text-gray-600 space-y-1">
          <li>• Günlük hayattan örnekler verin</li>
          <li>• Herkesi güldürecek olsun</li>
          <li>• Kısa ve etkili olsun</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Character Counter Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const textarea = document.querySelector('textarea[name="quote[content]"]');
  const charCount = document.getElementById('char-count');
  
  function updateCharCount() {
    const length = textarea.value.length;
    charCount.textContent = length + '/1000';
    
    if (length > 1000) {
      charCount.classList.add('text-red-500');
      charCount.classList.remove('text-gray-500');
    } else {
      charCount.classList.add('text-gray-500');
      charCount.classList.remove('text-red-500');
    }
  }
  
  textarea.addEventListener('input', updateCharCount);
  updateCharCount(); // Initial count
  
  // Make updateCharCount globally available for reset button
  window.updateCharCount = updateCharCount;
});
</script>
