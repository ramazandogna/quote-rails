<!-- Quote Detail Page -->
<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- Navigation Buttons -->
  <div class="flex justify-between items-center mb-8">
    <%= link_to root_path, class: "flex items-center space-x-2 text-gray-600 hover:text-gray-900 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      <span>Ana Sayfaya Dön</span>
    <% end %>

    <div class="flex items-center space-x-4">
      <% if @previous_quote %>
        <%= link_to @previous_quote, class: "bg-gray-100 hover:bg-gray-200 p-2 rounded-full transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
      <% end %>

      <% if @next_quote %>
        <%= link_to @next_quote, class: "bg-gray-100 hover:bg-gray-200 p-2 rounded-full transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Main Quote Card -->
  <div class="bg-white rounded-3xl shadow-2xl overflow-hidden mb-8">
    <!-- Background Pattern -->
    <div class="relative">
      <div class="absolute inset-0 bg-gradient-to-br <%= @quote.joke? ? 'from-yellow-400 to-orange-500' : 'from-purple-500 to-pink-500' %> opacity-10"></div>
      
      <!-- Header -->
      <div class="relative p-8 pb-6">
        <div class="flex items-center justify-between mb-6">
          <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium <%= @quote.joke? ? 'bg-yellow-100 text-yellow-800' : 'bg-purple-100 text-purple-800' %>">
            <%= @quote.joke? ? '😂 Komik Söz' : '💫 İlham Verici' %>
          </span>
          
          <div class="flex items-center text-gray-500 text-sm">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
            <span id="views-count"><%= @quote.views_count %></span>
          </div>
        </div>

        <!-- Quote Content -->
        <div class="mb-8">
          <blockquote class="text-2xl md:text-3xl leading-relaxed font-medium text-gray-800 text-center">
            "<%= @quote.content %>"
          </blockquote>
        </div>

        <!-- Author -->
        <div class="flex items-center justify-center mb-8">
          <div class="w-16 h-16 bg-gradient-to-r <%= @quote.joke? ? 'from-yellow-400 to-orange-500' : 'from-purple-500 to-pink-500' %> rounded-full flex items-center justify-center text-white font-bold text-xl mr-4">
            <%= @quote.user.initials %>
          </div>
          <div class="text-center">
            <p class="font-semibold text-lg text-gray-900"><%= @quote.user.full_name %></p>
            <% if @quote.user.linkedin_url.present? %>
              <%= link_to @quote.user.linkedin_url, target: "_blank", class: "text-blue-600 hover:text-blue-800 text-sm" do %>
                LinkedIn Profilini Gör
              <% end %>
            <% end %>
            <p class="text-sm text-gray-500"><%= time_ago_in_words(@quote.created_at) %> önce paylaşıldı</p>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-center space-x-8 py-6 border-t border-gray-100">
          <!-- Vote Buttons -->
          <button data-quote-id="<%= @quote.id %>" data-vote-type="like" class="vote-btn flex items-center space-x-3 bg-red-50 hover:bg-red-100 text-red-600 px-6 py-3 rounded-full transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
            <span class="likes-count font-semibold"><%= @quote.likes_count %></span>
          </button>

          <button data-quote-id="<%= @quote.id %>" data-vote-type="dislike" class="vote-btn flex items-center space-x-3 bg-blue-50 hover:bg-blue-100 text-blue-600 px-6 py-3 rounded-full transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 13l3 3 7-7"></path>
            </svg>
            <span class="dislikes-count font-semibold"><%= @quote.dislikes_count %></span>
          </button>

          <!-- Share Button -->
          <button class="flex items-center space-x-3 bg-green-50 hover:bg-green-100 text-green-600 px-6 py-3 rounded-full transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
            </svg>
            <span class="font-semibold">Paylaş</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Comments Section -->
  <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
    <div class="p-6 border-b border-gray-100">
      <h3 class="text-2xl font-bold text-gray-900 mb-4">Yorumlar (<%= @comments.count %>)</h3>
      
      <!-- Add Comment Form -->
      <%= form_with model: [@quote, @comment], local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
        <div>
          <%= f.text_area :content, placeholder: "Düşüncelerinizi paylaşın...", rows: 3, class: "w-full p-4 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none" %>
        </div>
        
        <div class="flex items-center justify-between">
          <%= f.text_field :anonymous_name, placeholder: "İsminiz (opsiyonel)", class: "flex-1 p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent mr-4" %>
          <%= f.submit "Yorum Yap", class: "bg-gradient-to-r from-purple-500 to-pink-500 text-white px-6 py-3 rounded-lg font-medium hover:from-purple-600 hover:to-pink-600 transition-all" %>
        </div>
      <% end %>
    </div>

    <!-- Comments List -->
    <div class="p-6" id="comments-list">
      <% if @comments.any? %>
        <div class="space-y-6">
          <% @comments.each do |comment| %>
            <div class="flex space-x-4 p-4 bg-gray-50 rounded-xl">
              <div class="w-10 h-10 bg-gradient-to-r from-gray-400 to-gray-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                <%= comment.display_name[0] %>
              </div>
              <div class="flex-1">
                <div class="flex items-center space-x-2 mb-2">
                  <span class="font-semibold text-gray-900"><%= comment.display_name %></span>
                  <span class="text-sm text-gray-500"><%= time_ago_in_words(comment.created_at) %> önce</span>
                </div>
                <p class="text-gray-800 leading-relaxed"><%= comment.content %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12">
          <div class="text-4xl mb-4">💬</div>
          <h4 class="text-xl font-semibold text-gray-900 mb-2">Henüz yorum yok</h4>
          <p class="text-gray-600">İlk yorumu siz yapın ve sohbeti başlatın!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- AJAX Vote Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const voteButtons = document.querySelectorAll('.vote-btn');
  
  voteButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      e.preventDefault();
      
      const quoteId = this.dataset.quoteId;
      const voteType = this.dataset.voteType;
      
      fetch(`/quotes/${quoteId}/vote`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
        },
        body: JSON.stringify({
          vote_type: voteType
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          document.querySelector('.likes-count').textContent = data.likes_count;
          document.querySelector('.dislikes-count').textContent = data.dislikes_count;
          
          // Show success message briefly
          const message = document.createElement('div');
          message.className = 'fixed top-20 right-4 z-50 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg';
          message.textContent = data.message;
          document.body.appendChild(message);
          
          setTimeout(() => {
            message.remove();
          }, 3000);
        }
      })
      .catch(error => {
        console.error('Vote error:', error);
      });
    });
  });
});
</script>
