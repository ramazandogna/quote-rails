<!-- Quote Card Component -->
<div class="group relative bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0 bg-gradient-to-br <%= quote.joke? ? 'from-yellow-400 to-orange-500' : 'from-purple-500 to-pink-500' %>"></div>
  </div>
  
  <!-- Card Header -->
  <div class="relative p-6 pb-4">
    <div class="flex items-center justify-between mb-4">
      <!-- Quote Type Badge -->
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= quote.joke? ? 'bg-yellow-100 text-yellow-800' : 'bg-purple-100 text-purple-800' %>">
        <%= quote.joke? ? '😂 Komik' : '💫 İlham Verici' %>
      </span>
      
      <!-- View Count -->
      <div class="flex items-center text-gray-500 text-sm">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </svg>
        <%= quote.views_count %>
      </div>
    </div>

    <!-- Quote Content -->
    <div class="mb-6">
      <%= link_to quote_path(quote), class: "block group-hover:text-purple-600 transition-colors" do %>
        <p class="text-gray-800 text-lg leading-relaxed font-medium">
          "<%= quote.short_content(150) %>"
        </p>
      <% end %>
    </div>

    <!-- Author Info -->
    <div class="flex items-center mb-4">
      <div class="w-10 h-10 bg-gradient-to-r <%= quote.joke? ? 'from-yellow-400 to-orange-500' : 'from-purple-500 to-pink-500' %> rounded-full flex items-center justify-center text-white font-bold text-sm mr-3">
        <%= quote.user.initials %>
      </div>
      <div>
        <p class="font-semibold text-gray-900"><%= quote.user.full_name %></p>
        <p class="text-sm text-gray-500"><%= time_ago_in_words(quote.created_at) %> önce</p>
      </div>
    </div>
  </div>

  <!-- Card Footer - Actions -->
  <div class="relative px-6 py-4 bg-gray-50 border-t border-gray-100">
    <div class="flex items-center justify-between">
      <!-- Vote Buttons -->
      <div class="flex items-center space-x-4">
        <!-- Like Button -->
        <button data-quote-id="<%= quote.id %>" data-vote-type="like" class="vote-btn flex items-center space-x-2 text-gray-600 hover:text-red-500 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          <span class="likes-count"><%= quote.likes_count %></span>
        </button>

        <!-- Dislike Button -->
        <button data-quote-id="<%= quote.id %>" data-vote-type="dislike" class="vote-btn flex items-center space-x-2 text-gray-600 hover:text-blue-500 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 13l3 3 7-7"></path>
          </svg>
          <span class="dislikes-count"><%= quote.dislikes_count %></span>
        </button>
      </div>

      <!-- Comments Count -->
      <%= link_to quote_path(quote), class: "flex items-center space-x-2 text-gray-600 hover:text-purple-500 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
        </svg>
        <span><%= quote.comments.count %></span>
      <% end %>

      <!-- Share Button -->
      <button class="flex items-center space-x-2 text-gray-600 hover:text-green-500 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
        </svg>
      </button>
    </div>
  </div>
</div>
