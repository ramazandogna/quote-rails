<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "QuoteRails - İlham Veren Sözler" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="İlham veren sözler, komik alıntılar ve hayat hikmetleri. QuoteRails ile duygularınızı paylaşın!">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Tailwind CSS %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    
    <%# Custom fonts from Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>

  <body class="bg-gray-50 font-sans antialiased">
    <!-- Navigation Header -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <%= link_to root_path, class: "flex items-center space-x-2" do %>
            <div class="w-8 h-8 bg-gradient-to-r from-purple-500 to-pink-500 rounded-lg flex items-center justify-center">
              <span class="text-white font-bold text-sm">Q</span>
            </div>
            <span class="font-bold text-xl text-gray-900">QuoteRails</span>
          <% end %>
          
          <!-- Navigation Links -->
          <div class="hidden md:flex items-center space-x-6">
            <%= link_to "Ana Sayfa", root_path, class: "text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
            <%= link_to "Komik", jokes_quotes_path, class: "text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
            <%= link_to "İlham Verici", inspiring_quotes_path, class: "text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
            <%= link_to "Rastgele", random_quotes_path, class: "text-gray-600 hover:text-gray-900 font-medium transition-colors" %>
            <%= link_to "Yeni Söz", new_quote_path, class: "bg-gradient-to-r from-purple-500 to-pink-500 text-white px-4 py-2 rounded-lg font-medium hover:from-purple-600 hover:to-pink-600 transition-all" %>
          </div>
          
          <!-- Mobile menu button -->
          <div class="md:hidden">
            <button type="button" class="text-gray-600 hover:text-gray-900 p-2" id="mobile-menu-toggle">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
      
      <!-- Mobile menu -->
      <div class="md:hidden hidden" id="mobile-menu">
        <div class="px-2 pt-2 pb-3 space-y-1 bg-white border-t border-gray-200">
          <%= link_to "Ana Sayfa", root_path, class: "block px-3 py-2 text-base font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md" %>
          <%= link_to "Komik", jokes_quotes_path, class: "block px-3 py-2 text-base font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md" %>
          <%= link_to "İlham Verici", inspiring_quotes_path, class: "block px-3 py-2 text-base font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md" %>
          <%= link_to "Rastgele", random_quotes_path, class: "block px-3 py-2 text-base font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md" %>
          <%= link_to "Yeni Söz", new_quote_path, class: "block px-3 py-2 text-base font-medium bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-md hover:from-purple-600 hover:to-pink-600" %>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-16 min-h-screen">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="fixed top-20 right-4 z-40 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg" data-turbo-temporary>
          <%= notice %>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="fixed top-20 right-4 z-40 bg-red-500 text-white px-4 py-2 rounded-lg shadow-lg" data-turbo-temporary>
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%# Import maps %>
    <%= javascript_importmap_tags %>
    
    <!-- Mobile menu toggle script -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        
        toggle?.addEventListener('click', function() {
          menu.classList.toggle('hidden');
        });
      });
    </script>
  </body>
</html>
